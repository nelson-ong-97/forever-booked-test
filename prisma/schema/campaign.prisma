// ============================================================================
// CAMPAIGN ENUMS
// ============================================================================

// Campaign lifecycle states. Designed as a state machine:
// DRAFT → PENDING_LAUNCH → LAUNCHING → ACTIVE → PAUSED/COMPLETED/CANCELLED
// Any state can transition to FAILED if an error occurs.
enum CampaignStatus {
  DRAFT // Initial state — campaign being configured
  PENDING_LAUNCH // User clicked launch, awaiting processing
  LAUNCHING // Meta API calls in progress
  ACTIVE // Successfully running on Meta
  PAUSED // Temporarily stopped (user or Meta)
  COMPLETED // Finished (schedule ended or budget exhausted)
  FAILED // Meta API error during launch or sync
  CANCELLED // Permanently stopped by user
}

// Maps to Meta's campaign objectives. Subset of Meta's full list,
// limited to what's relevant for medical spa advertising.
enum CampaignObjective {
  AWARENESS
  TRAFFIC
  ENGAGEMENT
  LEADS
  SALES
}

// Ad copy angles — each produces a different creative approach.
// These drive AI copy generation with different persuasion strategies.
enum AdAngleType {
  HOLIDAY_SEASONAL // Seasonal promotions (e.g., "Spring Botox Special")
  PAIN_POINT // Address customer problems (e.g., "Tired of...")
  SOCIAL_PROOF // Reviews, testimonials, results
  URGENCY_SCARCITY // Limited time/availability (e.g., "Only 5 spots left")
  BEFORE_AFTER // Transformation results
  EDUCATIONAL // Informative content about procedures
}

enum MediaType {
  IMAGE
  VIDEO
}

// Daily = Meta optimizes spend per day; Lifetime = total budget over schedule.
enum BudgetType {
  DAILY
  LIFETIME
}

// ============================================================================
// CAMPAIGN DOMAIN
// ============================================================================

// Maps to a Meta Campaign. Belongs to an offer and a clinic.
// clinic_id is denormalized here (could derive from offer → clinic) for:
// 1. Direct tenant-scoped queries without joining through offers
// 2. Index efficiency on (clinic_id, status) for dashboard filtering
model Campaign {
  id       String @id @default(uuid())
  clinicId String @map("clinic_id")
  offerId  String @map("offer_id")

  name      String
  objective CampaignObjective
  status    CampaignStatus    @default(DRAFT)

  // Meta API reference — null until successfully launched.
  // Storing Meta's ID lets us manage the campaign post-launch (pause/resume/cancel).
  metaCampaignId String? @map("meta_campaign_id")

  launchedAt   DateTime? @map("launched_at")
  errorMessage String?   @map("error_message") // Last error from Meta API

  // Idempotency key to prevent duplicate launches if user retries.
  // Generated client-side, checked server-side before Meta API call.
  idempotencyKey String? @unique @map("idempotency_key")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  clinic Clinic @relation(fields: [clinicId], references: [id])
  offer  Offer  @relation(fields: [offerId], references: [id])

  config    CampaignConfig?
  ads       Ad[]
  statusLog CampaignStatusLog[]
  syncLog   MetaSyncLog[]

  @@index([clinicId, status])
  @@index([offerId])
  @@index([metaCampaignId])
  @@map("campaigns")
}

// 1:1 with Campaign. Separated because:
// 1. Config is complex and changes independently from campaign metadata
// 2. Maps to a Meta Ad Set (different entity in Meta's hierarchy)
// 3. Keeps Campaign model focused on lifecycle, config on targeting/budget
model CampaignConfig {
  id         String @id @default(uuid())
  campaignId String @unique @map("campaign_id")

  budgetType   BudgetType @default(DAILY) @map("budget_type")
  budgetAmount Int        @map("budget_amount") // In cents — e.g., 2000 = $20.00/day

  // JSON for audience targeting — flexible because Meta's targeting options
  // are extensive and evolve. Normalized tables would be overly rigid.
  // e.g., {"age_min": 25, "age_max": 55, "genders": [2], "geo_locations": {"cities": [...]}}
  audienceTargeting Json @map("audience_targeting")

  // JSON array of placement strings — e.g., ["facebook_feed", "instagram_stories"]
  // Meta's placement options change frequently, JSON avoids migration churn.
  placements Json

  scheduleStart DateTime  @map("schedule_start")
  scheduleEnd   DateTime? @map("schedule_end") // Null = runs until manually stopped or budget exhausted

  // Meta Ad Set reference — null until launched.
  metaAdSetId String? @map("meta_ad_set_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_configs")
}

// Each ad represents one angle's creative within a campaign.
// Maps to a Meta Ad + Ad Creative.
// angle_type drives the AI copy generation approach.
model Ad {
  id         String @id @default(uuid())
  campaignId String @map("campaign_id")

  angleType AdAngleType @map("angle_type")
  angleName String      @map("angle_name") // Display name, e.g., "Holiday Special - Social Proof"

  // Ad copy fields — generated by AI, then editable by user
  headline    String?
  primaryText String? @map("primary_text")
  description String?
  ctaType     String? @map("cta_type") // e.g., "LEARN_MORE", "BOOK_NOW", "SHOP_NOW"

  // Meta references — null until launched
  metaAdId       String? @map("meta_ad_id")
  metaCreativeId String? @map("meta_creative_id")

  status CampaignStatus @default(DRAFT) // Individual ad status (can differ from campaign)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  campaign Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  media    AdMedia[]

  @@index([campaignId])
  @@map("ads")
}

// Media attachments for ads. Separate table because:
// 1. An ad can have multiple images/videos (carousel, A/B variants)
// 2. Media metadata (hash, dimensions) is distinct from ad copy
model AdMedia {
  id   String @id @default(uuid())
  adId String @map("ad_id")

  mediaType MediaType @map("media_type")
  mediaUrl  String    @map("media_url") // Cloud storage URL
  fileName  String?   @map("file_name")
  sortOrder Int       @default(0) @map("sort_order") // For carousel ordering

  // Meta's image hash — required for ad creation, returned after upload.
  // Stored to avoid re-uploading the same image.
  metaImageHash String? @map("meta_image_hash")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ad Ad @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@index([adId])
  @@map("ad_media")
}
